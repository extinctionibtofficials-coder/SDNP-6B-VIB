# PORT: usually set automatically by your host (Railway sets this itself).
# Only needed for local dev if you want a port other than 3000.
PORT=3000

# ADMIN_USERNAME: custom login username for /admin. Defaults to "admin" if left unset.
ADMIN_USERNAME=admin

# ADMIN_PASSWORD: protects the /admin panel with a login prompt (HTTP Basic Auth).
# Strongly recommended once this app is deployed publicly.
# If left unset, /admin is open to anyone who finds the URL (username is ignored too).
ADMIN_PASSWORD=test
